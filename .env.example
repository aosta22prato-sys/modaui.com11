# MODAUI Enterprise Infrastructure - Environment Template
# --------------------------------------------------
# 此文件定义了 MODAUI 企业级操作平台运行所需的关键变量。
# 生产环境请创建并配置 .env 文件。

# [Core Server Settings]
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# [Authentication - OAuth Providers]
# 配置后可在总后台动态启用
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# [Storage & Database]
# 默认使用本地 SQLite 存储: /data/modaui.db
DB_PATH=./data/modaui.db

# [Security]
SESSION_SECRET=moda_secure_session_key_replace_me_in_production
JWT_SECRET=moda_jwt_secret_token_replace_me_in_production

# [External Services]
# 顺丰速运 API 配置
SF_EXPRESS_CLIENT_CODE=
SF_EXPRESS_CHECK_WORD=

# 微信支付配置
WECHAT_MCH_ID=
WECHAT_API_KEY=
